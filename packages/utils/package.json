{
  "name": "@viclip/utils",
  "version": "1.0.0",
  "private": true,
  "description": "Shared utility functions for Viclip",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./date": {
      "types": "./src/date.ts",
      "default": "./src/date.ts"
    },
    "./text": {
      "types": "./src/text.ts",
      "default": "./src/text.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@viclip/tsconfig": "workspace:*",
    "typescript": "^5.9.3"
  }
}
