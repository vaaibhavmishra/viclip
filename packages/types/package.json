{
  "name": "@viclip/types",
  "license": "GPL-3.0-or-later",
  "version": "1.0.0",
  "private": true,
  "description": "Shared TypeScript types for Viclip",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./clipboard": {
      "types": "./src/clipboard.ts",
      "default": "./src/clipboard.ts"
    },
    "./device": {
      "types": "./src/device.ts",
      "default": "./src/device.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@viclip/tsconfig": "workspace:*",
    "typescript": "^5.9.3"
  }
}
