{
  "extends": "@viclip/tsconfig/base.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-native",
    "module": "preserve",
    "lib": ["DOM", "ESNext"],
    "moduleDetection": "force",
    "customConditions": ["react-native"],
    "noEmit": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "android",
    "ios"
  ]
}
