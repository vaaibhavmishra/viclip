  "main": "expo-router/entry",
  "scripts": {
    "start": "dotenv -e ../../.env -- expo start",
    "dev": "dotenv -v APP_VARIANT=development -e ../../.env -- expo start",
    "build": "dotenv -e ../../.env -- expo export",
    "build:android": "dotenv -e ../../.env -- expo run:android",
    "build:ios": "dotenv -e ../../.env -- expo run:ios",
    "clean": "rm -rf .expo .turbo dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@viclip/constants": "workspace:*",
    "@viclip/utils": "workspace:*",
    "@viclip/types": "workspace:*",
    "@expo/metro-runtime": "^55.0.10",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/database": "^24.0.0",
    "expo": "~55.0.17",
    "expo-blur": "^55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.28",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-insights": "~55.0.16",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-share-intent": "^6.0.0",
    "expo-splash-screen": "~55.0.19",
