{
  "extends": "@viclip/tsconfig/base.json",
  "references": [
    { "path": "../../packages/utils" },
    { "path": "../../packages/types" },
    { "path": "../../packages/constants" }
  ],
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "outDir": "dist",
    "composite": true,
    "types": ["electron-vite/node"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  }
}
