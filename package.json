{
  "name": "viclip",
  "version": "2.0.0",
  "private": true,
  "description": "ViClip monorepo for the website, desktop app, and mobile app.",
  "author": "Vaibhav Mishra <vaibhav@viclip.shipby.me>",
  "license": "Proprietary",
  "homepage": "https://viclip.shipby.me",
  "scripts": {
    "start": "turbo run start",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@viclip/web",
    "build:desktop": "turbo run build --filter=@viclip/desktop",
    "build:desktop:mac": "turbo run build:mac --filter=@viclip/desktop",
    "build:desktop:win": "turbo run build:win --filter=@viclip/desktop",
    "build:desktop:linux": "turbo run build:linux --filter=@viclip/desktop",
    "build:mobile": "turbo run build --filter=@viclip/mobile",
    "build:mobile:android": "turbo run build:android --filter=@viclip/mobile",
    "build:mobile:android:local": "turbo run build:android:local --filter=@viclip/mobile",
    "build:mobile:ios": "turbo run build:ios --filter=@viclip/mobile",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@viclip/web",
    "dev:desktop": "turbo run dev --filter=@viclip/desktop",
    "dev:mobile": "turbo run dev --filter=@viclip/mobile",
    "check": "biome check . --write",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@viclip/tsconfig": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "turbo": "^2.3.3",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": ">=22"
  }
}
